---
import "../styles/global.css";
import {
    Moon,
    Sun,
    Braces,
    Search,
    MousePointer2,
    Command,
} from "@lucide/astro";
import { ClientRouter } from "astro:transitions";
import { siteConfig } from "@/config";
import Footer from "@/components/Footer.astro";
import BackToTop from "@/components/BackToTop.astro";

interface Props {
    title?: string;
    description?: string;
    type?: string;
    image?: string;
}

const {
    title = siteConfig.title,
    description = siteConfig.description,
    type = "website",
    image,
} = Astro.props;

const canonicalURL = new URL(
    Astro.url.pathname,
    Astro.site || Astro.url.origin,
);

const normalize = (p: string) => p.replace(/\/+$/, "") || "/";

const isOnCurrentPath = (path: string) => {
    const currentPath = normalize(Astro.url.pathname);
    if (path === "/" && currentPath.startsWith("/page/")) return true;
    return currentPath === normalize(path);
};
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <ClientRouter />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="canonical" href={canonicalURL.href} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:type" content={type} />
        {
            image && (
                <meta
                    property="og:image"
                    content={
                        new URL(image, Astro.site || Astro.url.origin).href
                    }
                />
            )
        }
        {
            image && (
                <meta
                    name="twitter:image"
                    content={
                        new URL(image, Astro.site || Astro.url.origin).href
                    }
                />
            )
        }
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
        <script defer src="https://cloud.umami.is/script.js" data-website-id="2cfd0313-7a97-4c13-8d47-4367f08ad659"></script>
        <link
            rel="alternate"
            type="application/rss+xml"
            title={siteConfig.rss.title}
            href={new URL("feed.xml", Astro.url.origin)}
        />
        {
            siteConfig.analytics.umami.websiteId &&
                siteConfig.analytics.umami.src && (
                    <script
                        is:inline
                        defer
                        src={siteConfig.analytics.umami.src}
                        data-website-id={siteConfig.analytics.umami.websiteId}
                    />
                )
        }
        <script is:inline>
            const setDarkMode = () => {
                const theme = (() => {
                    if (
                        typeof localStorage !== "undefined" &&
                        localStorage.getItem("theme")
                    ) {
                        return localStorage.getItem("theme");
                    }
                    if (
                        window.matchMedia("(prefers-color-scheme: dark)")
                            .matches
                    ) {
                        return "dark";
                    }
                    return "light";
                })();
                if (theme === "light") {
                    document.documentElement.classList.remove("dark");
                } else {
                    document.documentElement.classList.add("dark");
                }
            };
            setDarkMode();
            document.addEventListener("astro:after-swap", setDarkMode);
        </script>
    </head>
    <body class="max-w-page mx-auto min-h-screen flex flex-col">
        <nav
            id="main-nav"
            class="px-5 py-5 flex justify-between sticky top-0 z-50"
        >
            <a href="/" class="flex items-center" aria-label="Home">
                <Braces />
            </a>

            <ul class="flex items-center gap-4">
                <li>
                    <a href="/" class={isOnCurrentPath("/") ? "active" : ""}>
                        <span class={isOnCurrentPath("/") ? "" : "nav-link"}>
                            home
                        </span>
                    </a>
                </li>
                <li>
                    <button
                        id="palette-toggle"
                        type="button"
                        aria-label="Open command palette"
                        class="flex items-center cursor-pointer text-muted-foreground hover:text-foreground transition-colors gap-1.5 px-2 py-1 rounded-md border border-border hover:bg-secondary"
                    >
                        <Command size={16} />
                        <span class="text-xs hidden sm:inline">Explore</span>
                        <kbd
                            class="text-[10px] text-muted-foreground hidden md:inline ml-1 border border-border rounded px-1 py-0.5"
                        >
                            ^P
                        </kbd>
                    </button>
                </li>
                <li>
                    <button
                        id="theme-toggle"
                        type="button"
                        aria-label="Toggle dark mode"
                        class="flex items-center cursor-pointer"
                    >
                        <Moon class="block dark:hidden" size={16} />
                        <Sun class="hidden dark:block" size={16} />
                    </button>
                </li>
                <li>
                    <button
                        id="cursor-toggle"
                        type="button"
                        aria-label="Toggle custom cursor"
                        class="flex items-center transition-opacity cursor-pointer"
                    >
                        <MousePointer2 size={16} />
                    </button>
                </li>
            </ul>
        </nav>
        <div class="flex-1" style="view-transition-name: main-content;">
            <slot />
        </div>
        <div style="view-transition-name: page-footer;">
            <Footer />
        </div>
        <BackToTop />

        <!-- Command Palette Overlay -->
        <div
            id="palette-overlay"
            class="fixed inset-0 z-100 bg-background/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 flex items-start justify-center pt-20 sm:pt-32 px-4 disable-select"
            aria-hidden="true"
            inert
        >
            <div
                id="palette-modal"
                class="bg-card w-full max-w-xl rounded-xl border border-border shadow-2xl scale-95 transition-transform duration-300 flex flex-col overflow-hidden max-h-[80vh]"
            >
                <!-- Input -->
                <div
                    class="flex items-center px-4 py-3 border-b border-border gap-3"
                >
                    <Search class="text-muted-foreground shrink-0" size={18} />
                    <input
                        type="text"
                        id="palette-input"
                        class="flex-1 bg-transparent border-none outline-none text-foreground placeholder:text-muted-foreground"
                        placeholder="Type a command or search..."
                        autocomplete="off"
                    />
                    <button
                        id="palette-close"
                        class="text-xs text-muted-foreground bg-secondary px-2 py-1 rounded hidden sm:block cursor-pointer shrink-0"
                        >ESC</button
                    >
                </div>

                <!-- Results -->
                <div
                    id="palette-results"
                    class="overflow-y-auto p-2 flex flex-col gap-0.5"
                >
                </div>
                <div
                    id="palette-empty"
                    class="py-14 text-center text-sm text-muted-foreground hidden"
                >
                    No results found.
                </div>
            </div>
        </div>

        <div
            id="cursor"
            class="bg-primary mix-blend-hard-light opacity-0 size-3 rounded-full pointer-events-none z-9999 fixed top-0 left-0"
            transition:persist
        >
        </div>
        <script src="../scripts/cursor.ts"></script>
        <script>
            import type { SearchItem } from "../types";

            let onThemeToggleClick: ((e: MouseEvent) => void) | null = null;
            let onPaletteToggleClick: ((e: MouseEvent) => void) | null = null;
            let onPaletteCloseClick: ((e: MouseEvent) => void) | null = null;
            let onPaletteOverlayClick: ((e: MouseEvent) => void) | null = null;
            let onPaletteKeydown: ((e: KeyboardEvent) => void) | null = null;
            let onPaletteInput: ((e: Event) => void) | null = null;
            let onPaletteKeyNav: ((e: KeyboardEvent) => void) | null = null;
            let searchData: SearchItem[] | null = null;

            let onNavScroll: (() => void) | null = null;
            let lastScrollY = 0;

            const navCommands = [
                { label: "/home", href: "/", description: "Go to home" },
                { label: "/about", href: "/about", description: "About me" },
                {
                    label: "/portfolio",
                    href: "/portfolio",
                    description: "My projects",
                },
                { label: "/blog", href: "/blog", description: "Blog archive" },
                {
                    label: "/now",
                    href: "/now",
                    description: "What I'm doing now",
                },
                { label: "/uses", href: "/uses", description: "My setup" },
            ];

            const moonSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`;
            const rssSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>`;

            const actionCommands = [
                { id: "theme", label: "Toggle dark mode", icon: moonSvg },
                {
                    id: "rss",
                    label: "Subscribe to RSS",
                    href: "/feed.xml",
                    icon: rssSvg,
                },
            ];

            document.addEventListener("astro:before-swap", () => {
                const themeToggle = document.getElementById("theme-toggle");
                if (onThemeToggleClick && themeToggle) {
                    themeToggle.removeEventListener(
                        "click",
                        onThemeToggleClick,
                    );
                    onThemeToggleClick = null;
                }

                const paletteToggle = document.getElementById("palette-toggle");
                const paletteClose = document.getElementById("palette-close");
                const paletteOverlay =
                    document.getElementById("palette-overlay");
                const paletteInput = document.getElementById("palette-input");

                if (onPaletteToggleClick && paletteToggle)
                    paletteToggle.removeEventListener(
                        "click",
                        onPaletteToggleClick,
                    );
                if (onPaletteCloseClick && paletteClose)
                    paletteClose.removeEventListener(
                        "click",
                        onPaletteCloseClick,
                    );
                if (onPaletteOverlayClick && paletteOverlay)
                    paletteOverlay.removeEventListener(
                        "click",
                        onPaletteOverlayClick,
                    );
                if (onPaletteInput && paletteInput)
                    paletteInput.removeEventListener("input", onPaletteInput);
                if (onPaletteKeyNav)
                    document.removeEventListener("keydown", onPaletteKeyNav);
                if (onPaletteKeydown)
                    document.removeEventListener("keydown", onPaletteKeydown);

                onPaletteToggleClick = null;
                onPaletteCloseClick = null;
                onPaletteOverlayClick = null;
                onPaletteInput = null;
                onPaletteKeyNav = null;
                onPaletteKeydown = null;

                if (onNavScroll) {
                    window.removeEventListener("scroll", onNavScroll);
                    onNavScroll = null;
                }
            });

            document.addEventListener("astro:page-load", () => {
                // back/forward navigation detection for view transitions
                if (navigation) {
                    navigation.addEventListener('navigate', (e) => {
                        if (e.navigationType === 'traverse') {
                            document.documentElement.classList.add('back-transition');
                        } else {
                            document.documentElement.classList.remove('back-transition');
                        }
                    });
                }
                window.addEventListener('popstate', () => {
                    document.documentElement.classList.add('back-transition');
                    setTimeout(() => {
                        document.documentElement.classList.remove('back-transition');
                    }, 500);
                });

                const themeToggle = document.getElementById("theme-toggle");
                if (!themeToggle) return;

                onThemeToggleClick = (event: MouseEvent) => {
                    const isDark =
                        document.documentElement.classList.contains("dark");

                    const toggleTheme = () => {
                        if (isDark) {
                            document.documentElement.classList.remove("dark");
                            localStorage.setItem("theme", "light");
                        } else {
                            document.documentElement.classList.add("dark");
                            localStorage.setItem("theme", "dark");
                        }
                    };

                    if (!document.startViewTransition) {
                        toggleTheme();
                        return;
                    }

                    const x = event.clientX;
                    const y = event.clientY;
                    const endRadius = Math.hypot(
                        Math.max(x, innerWidth - x),
                        Math.max(y, innerHeight - y),
                    );

                    document.documentElement.classList.add("theme-transition");

                    const transition = document.startViewTransition(() => {
                        toggleTheme();
                    });

                    transition.ready.then(() => {
                        const clipPath = [
                            `circle(0px at ${x}px ${y}px)`,
                            `circle(${endRadius}px at ${x}px ${y}px)`,
                        ];

                        document.documentElement.animate(
                            { clipPath: clipPath },
                            {
                                duration: 500,
                                easing: "ease-in-out",
                                pseudoElement: "::view-transition-new(root)",
                            },
                        );
                    });

                    transition.finished.finally(() => {
                        document.documentElement.classList.remove(
                            "theme-transition",
                        );
                    });
                };

                themeToggle.addEventListener("click", onThemeToggleClick);

                // --- Command Palette Logic ---

                const paletteToggle = document.getElementById("palette-toggle");
                const paletteClose = document.getElementById("palette-close");
                const paletteOverlay =
                    document.getElementById("palette-overlay");
                const paletteModal = document.getElementById("palette-modal");
                const paletteInput = document.getElementById(
                    "palette-input",
                ) as HTMLInputElement;
                const resultsContainer =
                    document.getElementById("palette-results");
                const emptyState = document.getElementById("palette-empty");

                const renderPalette = (query: string) => {
                    if (!resultsContainer || !emptyState) return;

                    const q = query.trim().toLowerCase();

                    // Filter nav commands
                    const filteredNav = navCommands.filter(
                        (cmd) =>
                            !q ||
                            cmd.label.toLowerCase().includes(q) ||
                            cmd.description.toLowerCase().includes(q),
                    );

                    // Filter action commands
                    const filteredActions = actionCommands.filter(
                        (cmd) => !q || cmd.label.toLowerCase().includes(q),
                    );

                    // Search posts
                    let filteredPosts: SearchItem[] = [];
                    if (q && searchData) {
                        filteredPosts = searchData.filter(
                            (post) =>
                                post.title.toLowerCase().includes(q) ||
                                post.frontmatter.toLowerCase().includes(q) ||
                                post.tags.some((tag) =>
                                    tag.toLowerCase().includes(q),
                                ),
                        );
                    }

                    const hasResults =
                        filteredNav.length > 0 ||
                        filteredActions.length > 0 ||
                        filteredPosts.length > 0;

                    if (!hasResults && q) {
                        resultsContainer.classList.add("hidden");
                        emptyState.classList.remove("hidden");
                        return;
                    }

                    emptyState.classList.add("hidden");
                    resultsContainer.classList.remove("hidden");

                    let html = "";

                    // Nav commands section
                    if (filteredNav.length > 0) {
                        html += `<div class="text-[10px] uppercase tracking-widest text-muted-foreground px-3 py-2 font-medium">Navigate</div>`;
                        for (const cmd of filteredNav) {
                            html += `
                                <a href="${cmd.href}" class="palette-item">
                                <div class="flex items-center justify-between w-full">
                                        <span class="text-muted-foreground text-xs font-mono">${cmd.label}</span>
                                        <span class="text-sm text-muted-foreground">${cmd.description}</span>
                                    </div>
                                </a>
                            `;
                        }
                    }

                    // Action commands section
                    if (filteredActions.length > 0) {
                        html += `<div class="text-[10px] uppercase tracking-widest text-muted-foreground px-3 py-2 mt-1 font-medium">Actions</div>`;
                        for (const cmd of filteredActions) {
                            if (cmd.id === "theme") {
                                html += `
                                    <button class="palette-item w-full text-left" data-action="theme">
                                        <div class="flex items-center gap-3">
                                            <span class="text-xs">${cmd.icon}</span>
                                            <span class="text-sm">${cmd.label}</span>
                                        </div>
                                    </button>
                                `;
                            } else {
                                html += `
                                    <a href="${cmd.href}" class="palette-item">
                                        <div class="flex items-center gap-3">
                                            <span class="text-xs">${cmd.icon}</span>
                                            <span class="text-sm">${cmd.label}</span>
                                        </div>
                                    </a>
                                `;
                            }
                        }
                    }

                    // Search results section
                    if (filteredPosts.length > 0) {
                        html += `<div class="text-[10px] uppercase tracking-widest text-muted-foreground px-3 py-2 mt-1 font-medium">Posts</div>`;
                        for (const post of filteredPosts) {
                            html += `
                                <a href="${post.link}" class="palette-item">
                                    <div class="flex flex-col gap-0.5 w-full">
                                        <div class="flex justify-between items-center">
                                            <span class="text-sm font-medium">${post.title}</span>
                                            <span class="text-[10px] text-muted-foreground shrink-0 ml-4">${post.readTime} min · ${post.date}</span>
                                        </div>
                                        <span class="text-xs text-muted-foreground line-clamp-1">${post.frontmatter}</span>
                                    </div>
                                </a>
                            `;
                        }
                    }

                    resultsContainer.innerHTML = html;

                    // Bind click handlers for action buttons
                    resultsContainer
                        .querySelectorAll("[data-action='theme']")
                        .forEach((btn) => {
                            btn.addEventListener("click", () => {
                                closePalette();
                                setTimeout(() => themeToggle?.click(), 50);
                            });
                        });
                };

                const renderInitialCommands = () => {
                    if (!resultsContainer || !emptyState) return;
                    emptyState.classList.add("hidden");
                    resultsContainer.classList.remove("hidden");

                    let html = "";

                    html += `<div class="text-[10px] uppercase tracking-widest text-muted-foreground px-3 py-2 font-medium">Navigate</div>`;
                    for (const cmd of navCommands) {
                        html += `
                            <a href="${cmd.href}" class="palette-item">
                                <div class="flex items-center justify-between w-full">
                                    <span class="text-muted-foreground text-xs font-mono">${cmd.label}</span>
                                    <span class="text-sm text-muted-foreground">${cmd.description}</span>
                                </div>
                            </a>
                        `;
                    }

                    html += `<div class="text-[10px] uppercase tracking-widest text-muted-foreground px-3 py-2 mt-1 font-medium">Actions</div>`;
                    for (const cmd of actionCommands) {
                        if (cmd.id === "theme") {
                            html += `
                                <button class="palette-item w-full text-left" data-action="theme">
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs">${cmd.icon}</span>
                                        <span class="text-sm">${cmd.label}</span>
                                    </div>
                                </button>
                            `;
                        } else {
                            html += `
                                <a href="${cmd.href}" class="palette-item">
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs">${cmd.icon}</span>
                                        <span class="text-sm">${cmd.label}</span>
                                    </div>
                                </a>
                            `;
                        }
                    }

                    resultsContainer.innerHTML = html;

                    resultsContainer
                        .querySelectorAll("[data-action='theme']")
                        .forEach((btn) => {
                            btn.addEventListener("click", () => {
                                closePalette();
                                setTimeout(() => themeToggle?.click(), 50);
                            });
                        });
                };

                const openPalette = async () => {
                    if (!paletteOverlay || !paletteModal || !paletteInput)
                        return;
                    paletteOverlay.removeAttribute("inert");
                    paletteOverlay.setAttribute("aria-hidden", "false");
                    paletteOverlay.classList.remove(
                        "opacity-0",
                        "pointer-events-none",
                    );
                    paletteOverlay.classList.add("opacity-100");
                    paletteModal.classList.remove("scale-95");
                    paletteModal.classList.add("scale-100");
                    document.body.style.overflow = "hidden";
                    setTimeout(() => paletteInput.focus(), 50);

                    if (paletteInput) paletteInput.value = "";
                    renderInitialCommands();

                    if (!searchData) {
                        try {
                            const res = await fetch("/search.json");
                            searchData = await res.json();
                        } catch (e) {
                            console.error("Failed to load search index", e);
                        }
                    }
                };

                const closePalette = () => {
                    if (!paletteOverlay || !paletteModal) return;
                    paletteOverlay.setAttribute("inert", "");
                    paletteOverlay.setAttribute("aria-hidden", "true");
                    paletteOverlay.classList.add(
                        "opacity-0",
                        "pointer-events-none",
                    );
                    paletteOverlay.classList.remove("opacity-100");
                    paletteModal.classList.add("scale-95");
                    paletteModal.classList.remove("scale-100");
                    document.body.style.overflow = "";
                };

                // Palette keyboard navigation
                let activeIndex = -1;

                const updateActiveItem = (index: number) => {
                    const items =
                        resultsContainer?.querySelectorAll(".palette-item");
                    if (!items) return;
                    items.forEach((el, i) => {
                        if (i === index) {
                            el.classList.add("palette-item-active");
                            el.scrollIntoView({ block: "nearest" });
                        } else {
                            el.classList.remove("palette-item-active");
                        }
                    });
                };

                onPaletteKeyNav = (e: KeyboardEvent) => {
                    if (
                        !paletteOverlay ||
                        paletteOverlay.getAttribute("inert") !== null
                    )
                        return;

                    const items =
                        resultsContainer?.querySelectorAll(".palette-item");
                    if (!items || items.length === 0) return;

                    if (e.key === "ArrowDown") {
                        e.preventDefault();
                        activeIndex = Math.min(
                            activeIndex + 1,
                            items.length - 1,
                        );
                        updateActiveItem(activeIndex);
                    } else if (e.key === "ArrowUp") {
                        e.preventDefault();
                        activeIndex = Math.max(activeIndex - 1, 0);
                        updateActiveItem(activeIndex);
                    } else if (e.key === "Enter") {
                        e.preventDefault();
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            const el = items[activeIndex] as HTMLElement;
                            if (el.tagName === "A") {
                                closePalette();
                                const href = el.getAttribute("href");
                                if (href) window.location.href = href;
                            } else if (el.dataset.action === "theme") {
                                closePalette();
                                setTimeout(() => themeToggle?.click(), 50);
                            }
                        }
                    }
                };

                document.addEventListener("keydown", onPaletteKeyNav);

                onPaletteToggleClick = () => {
                    activeIndex = -1;
                    openPalette();
                };
                onPaletteCloseClick = () => closePalette();
                onPaletteOverlayClick = (e: MouseEvent) => {
                    if (e.target === paletteOverlay) {
                        activeIndex = -1;
                        closePalette();
                    }
                };
                onPaletteInput = () => {
                    activeIndex = -1;
                    renderPalette(paletteInput?.value || "");
                };
                onPaletteKeydown = (e: KeyboardEvent) => {
                    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                        e.preventDefault();
                        activeIndex = -1;
                        openPalette();
                    } else if (
                        (e.metaKey || e.ctrlKey) &&
                        e.shiftKey &&
                        (e.key === "p" || e.key === "P")
                    ) {
                        e.preventDefault();
                        activeIndex = -1;
                        openPalette();
                    } else if (e.key === "Escape") {
                        activeIndex = -1;
                        closePalette();
                    }
                };

                if (paletteToggle)
                    paletteToggle.addEventListener(
                        "click",
                        onPaletteToggleClick,
                    );
                if (paletteClose)
                    paletteClose.addEventListener("click", onPaletteCloseClick);
                if (paletteOverlay)
                    paletteOverlay.addEventListener(
                        "click",
                        onPaletteOverlayClick,
                    );
                if (paletteInput)
                    paletteInput.addEventListener("input", onPaletteInput);
                document.addEventListener("keydown", onPaletteKeydown);

                // magnetic buttons
                const magneticEls = document.querySelectorAll("[data-magnetic]");
                const applyMagnetic = (el, e) => {
                    const rect = el.getBoundingClientRect();
                    const x = e.clientX - rect.left - rect.width / 2;
                    const y = e.clientY - rect.top - rect.height / 2;
                    const strength = Math.min(el.dataset.magneticStrength || 12, 20);
                    el.style.transform = `translate(${x * (strength / (rect.width / 2))}px, ${y * (strength / (rect.height / 2))}px)`;
                };
                const removeMagnetic = (el) => {
                    el.style.transform = 'translate(0, 0)';
                };
                magneticEls.forEach((el) => {
                    el.addEventListener('mousemove', (e) => applyMagnetic(el, e));
                    el.addEventListener('mouseleave', () => removeMagnetic(el));
                });
                document.addEventListener('astro:after-swap', () => {
                    document.querySelectorAll("[data-magnetic]").forEach((el) => {
                        el.addEventListener('mousemove', (e) => applyMagnetic(el, e));
                        el.addEventListener('mouseleave', () => removeMagnetic(el));
                    });
                });

                // scroll-aware navbar
                const nav = document.getElementById("main-nav");
                if (nav) {
                    lastScrollY = window.scrollY;

                    onNavScroll = () => {
                        const currentY = window.scrollY;

                        if (currentY > 100) {
                            nav.classList.add("nav-scrolled");
                        } else {
                            nav.classList.remove("nav-scrolled");
                        }

                        if (currentY > lastScrollY && currentY > 200) {
                            nav.classList.add("nav-hidden");
                        } else {
                            nav.classList.remove("nav-hidden");
                        }

                        lastScrollY = currentY;
                    };

                    window.addEventListener("scroll", onNavScroll);
                }
            });
        </script>
    </body>
</html>
