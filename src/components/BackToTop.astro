---
import { ArrowUp } from "@lucide/astro";
---

<button
    id="back-to-top"
    aria-label="Back to top"
    class="fixed bottom-6 left-6 z-40 bg-secondary text-foreground size-10 rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 hover:bg-primary hover:text-primary-foreground hover:scale-110 border border-border"
>
    <ArrowUp size={18} />
</button>

<script>
    let onScroll: (() => void) | null = null;
    let onClick: (() => void) | null = null;

    document.addEventListener("astro:before-swap", () => {
        if (onScroll) {
            window.removeEventListener("scroll", onScroll);
            onScroll = null;
        }
        const btn = document.getElementById("back-to-top");
        if (onClick && btn) {
            btn.removeEventListener("click", onClick);
            onClick = null;
        }
    });

    document.addEventListener("astro:page-load", () => {
        const btn = document.getElementById("back-to-top");
        if (!btn) return;

        onScroll = () => {
            if (window.scrollY > 400) {
                btn.classList.remove("opacity-0", "pointer-events-none");
                btn.classList.add("opacity-100", "pointer-events-auto");
            } else {
                btn.classList.add("opacity-0", "pointer-events-none");
                btn.classList.remove("opacity-100", "pointer-events-auto");
            }
        };

        onClick = () => {
            window.scrollTo({ top: 0, behavior: "smooth" });
        };

        window.addEventListener("scroll", onScroll);
        btn.addEventListener("click", onClick);
    });
</script>
