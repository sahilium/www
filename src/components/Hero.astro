---
import { Image } from "astro:assets";
import avatar from "@/assets/images/avatar.jpg";
import statuses from "@/data/statuses.json";
---

<div class="hero" id="hero-root" data-statuses={JSON.stringify(statuses)}>
    <div class="hero-avatar-wrap">
        <Image src={avatar} alt="Sahil A." class="hero-avatar" />
    </div>
    <div class="hero-status" id="hero-status">
        <span class="status-name">Sahil</span>
        <span class="status-verb" id="status-verb"></span>
        <span class="status-sentence" id="status-sentence"></span>
    </div>
</div>

<script>
    function setStatus() {
        const root = document.getElementById('hero-root');
        const statuses = JSON.parse(root?.dataset.statuses || '[]');

        const verbEl = document.getElementById('status-verb');
        const sentenceEl = document.getElementById('status-sentence');

        if (verbEl && sentenceEl && statuses.length) {
            const i = Math.floor(Math.random() * statuses.length);
            verbEl.textContent = statuses[i].verb;
            sentenceEl.textContent = statuses[i].sentence;
        }
    }

    setStatus();
    document.addEventListener('astro:page-load', setStatus);
</script>

<style>
    .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem 0.5rem;
        text-align: center;
    }

    .hero-avatar-wrap {
        flex-shrink: 0;
    }

    .hero-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        object-fit: cover;
        animation: float 6s ease-in-out infinite;
        box-shadow: 0 5px 15px 0px rgba(0, 0, 0, 0.3);
    }

    @keyframes float {
        0% {
            box-shadow: 0 5px 15px 0px rgba(0, 0, 0, 0.3);
            transform: translateY(0px);
        }
        50% {
            box-shadow: 0 25px 15px 0px rgba(0, 0, 0, 0.1);
            transform: translateY(-8px);
        }
        100% {
            box-shadow: 0 5px 15px 0px rgba(0, 0, 0, 0.3);
            transform: translateY(0px);
        }
    }

    .hero-status {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.15rem;
    }

    .status-name {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.2;
        font-family: var(--font-sans, "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif);
    }

    .status-verb {
        font-size: 0.85rem;
        color: var(--primary);
        font-weight: 500;
        text-transform: lowercase;
        letter-spacing: 0.05em;
    }

    .status-sentence {
        font-size: 0.95rem;
        color: var(--muted-foreground);
        font-style: italic;
        max-width: 32ch;
    }

    @media (min-width: 640px) {
        .hero {
            padding: 1rem 2rem 0.75rem;
            gap: 1rem;
        }
        .hero-avatar {
            width: 88px;
            height: 88px;
        }
        .status-name {
            font-size: 1.75rem;
        }
        .status-verb {
            font-size: 0.9rem;
        }
        .status-sentence {
            font-size: 1rem;
        }
    }
</style>
