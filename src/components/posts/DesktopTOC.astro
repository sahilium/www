---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
---

<aside class="hidden lg:block w-64 shrink-0">
    <div class="sticky top-20 border border-border rounded-md p-5 bg-card/30">
        <h3 class="text-xs uppercase tracking-widest font-semibold flex items-center gap-2 mb-4 text-primary">
            <span class="text-muted-foreground">#</span> //
            CONTENTS
        </h3>
        <ul class="flex flex-col gap-3 text-sm border-l border-border pl-0">
            {headings.map((heading) => (
                <li class="relative">
                    <a
                        href={`#${heading.slug}`}
                        class="text-muted-foreground hover:text-foreground transition-colors block pl-4"
                    >
                        {heading.text}
                    </a>
                </li>
            ))}
        </ul>
    </div>
</aside>
