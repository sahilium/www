---
import { List, X } from "@lucide/astro";

interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
---

<div class="fixed bottom-6 right-6 z-50 lg:hidden block">
  <div
    id="mobile-toc-menu"
    class="absolute bottom-16 right-0 w-64 border border-border rounded-xl p-5 bg-card shadow-xl opacity-0 scale-95 pointer-events-none transition-all duration-200 origin-bottom-right"
  >
    <h3
      class="text-xs uppercase tracking-widest font-semibold flex items-center gap-2 mb-4 text-primary"
    >
      <span class="text-muted-foreground">#</span> // CONTENTS
    </h3>
    <ul
      class="flex flex-col gap-3 text-sm border-l border-border pl-0 max-h-[60vh] overflow-y-auto overscroll-contain"
    >
      {
        headings.map((heading) => (
          <li class="relative">
            <a
              href={`#${heading.slug}`}
              class="text-muted-foreground hover:text-foreground transition-colors block pl-4"
            >
              {heading.text}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <button
    id="mobile-toc-fab"
    aria-label="Table of Contents"
    class="bg-primary text-primary-foreground size-12 rounded-full shadow-lg flex items-center justify-center hover:scale-105 active:scale-95 transition-all border border-border"
  >
    <List size={20} class="fab-icon-list transition-transform" />
    <X
      size={20}
      class="fab-icon-x absolute opacity-0 scale-50 transition-all"
    />
  </button>
</div>

<script is:inline>
  let onDocumentClick = null;

  document.addEventListener(
    "astro:before-swap",
    () => {
      if (onDocumentClick) {
        document.removeEventListener("click", onDocumentClick);
        onDocumentClick = null;
      }
    },
    { once: true },
  );

  document.addEventListener("astro:page-load", () => {
    const fabButton = document.getElementById("mobile-toc-fab");
    const menu = document.getElementById("mobile-toc-menu");
    const iconList = document.querySelector(".fab-icon-list");
    const iconX = document.querySelector(".fab-icon-x");
    let isOpen = false;

    if (!fabButton || !menu) return;

    const menuClosed = ["opacity-0", "scale-95", "pointer-events-none"];
    const menuOpen = ["opacity-100", "scale-100", "pointer-events-auto"];
    const iconHidden = ["opacity-0", "scale-50"];
    const iconListClosed = ["opacity-0", "rotate-90", "scale-50"];
    const iconXOpen = ["opacity-100", "rotate-0", "scale-100"];

    const toggleMenu = () => {
      isOpen = !isOpen;

      if (isOpen) {
        menu.classList.remove(...menuClosed);
        menu.classList.add(...menuOpen);

        iconList.classList.add(...iconListClosed);
        iconX.classList.remove(...iconHidden);
        iconX.classList.add(...iconXOpen);
      } else {
        menu.classList.remove(...menuOpen);
        menu.classList.add(...menuClosed);

        iconList.classList.remove(...iconListClosed);
        iconX.classList.remove(...iconXOpen);
        iconX.classList.add(...iconHidden);
      }
    };

    fabButton.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    onDocumentClick = (e) => {
      if (isOpen && !menu.contains(e.target)) {
        toggleMenu();
      }
    };
    document.addEventListener("click", onDocumentClick);

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        if (isOpen) toggleMenu();
      });
    });
  });
</script>
