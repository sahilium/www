---
import { CheckCircle2, XCircle } from "@lucide/astro";

export interface Props {
  pros: string[];
  cons: string[];
}

const { pros = [], cons = [] } = Astro.props;
---
<div class="my-8 grid gap-4 grid-cols-1 md:grid-cols-2 text-sm w-full">
  <div class="rounded-xl border border-emerald-100 dark:border-emerald-900/50 bg-emerald-50/50 dark:bg-emerald-900/10 p-5">
    <div class="font-semibold flex items-center gap-2 text-emerald-800 dark:text-emerald-400 mb-4">
      <CheckCircle2 size={18} />
      <span>Pros</span>
    </div>
    <ul class="space-y-2 m-0 p-0 list-none">
      {pros.map(pro => (
        <li class="flex items-start gap-2 text-neutral-700 dark:text-neutral-300">
          <span class="text-emerald-500 shrink-0 mt-0.5">•</span>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>
  
  <div class="rounded-xl border border-red-100 dark:border-red-900/50 bg-red-50/50 dark:bg-red-900/10 p-5">
    <div class="font-semibold flex items-center gap-2 text-red-800 dark:text-red-400 mb-4">
      <XCircle size={18} />
      <span>Cons</span>
    </div>
    <ul class="space-y-2 m-0 p-0 list-none">
      {cons.map(con => (
        <li class="flex items-start gap-2 text-neutral-700 dark:text-neutral-300">
           <span class="text-red-500 shrink-0 mt-0.5">•</span>
           <span>{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
