---
import { Link } from "@lucide/astro";

export interface Props {
  href: string;
  title: string;
  description?: string;
  domain?: string;
}

const { href, title, description, domain } = Astro.props;
const displayDomain = domain || new URL(href).hostname;
---
<a href={href} target="_blank" rel="noopener noreferrer" class="my-8 block no-underline group shadow-sm rounded-xl">
  <div class="flex items-center overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-950 transition-colors hover:bg-neutral-50 dark:hover:bg-neutral-900/80 hover:border-indigo-300 dark:hover:border-indigo-700">
    <div class="flex-1 p-4 sm:p-5">
      <div class="font-semibold text-neutral-900 dark:text-white mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors line-clamp-1">{title}</div>
      {description && <div class="text-sm text-neutral-500 dark:text-neutral-400 mb-3 line-clamp-2 leading-relaxed">{description}</div>}
      <div class="text-xs font-medium text-neutral-400 dark:text-neutral-500 flex items-center gap-1.5 mt-auto">
        <Link size={12} />
        {displayDomain}
      </div>
    </div>
  </div>
</a>
