---
import { Quote as QuoteIcon } from "@lucide/astro";

const { author, title } = Astro.props;
---
<figure class="my-8 rounded-xl bg-neutral-50 dark:bg-neutral-900/50 p-6 sm:p-8 flex items-start gap-4 border border-neutral-100 dark:border-neutral-800 shadow-sm">
  <div class="text-indigo-500/30 flex-shrink-0 pt-1">
    <QuoteIcon size={32} />
  </div>
  <div class="flex-1 w-0">
    <blockquote class="text-lg/relaxed font-medium italic text-neutral-800 dark:text-neutral-200 m-0 p-0 border-0">
      <slot />
    </blockquote>
    {(author || title) && (
      <figcaption class="mt-4 flex items-center gap-2">
        {author && <span class="font-semibold text-neutral-900 dark:text-white">{author}</span>}
        {author && title && <span class="text-neutral-400 dark:text-neutral-500">—</span>}
        {title && <span class="text-sm text-neutral-500 dark:text-neutral-400">{title}</span>}
      </figcaption>
    )}
  </div>
</figure>
