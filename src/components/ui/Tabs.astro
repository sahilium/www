---
export interface Props {
  tabs: string[];
}
const { tabs } = Astro.props;
---

<div
  class="tabs-container block my-6 border border-neutral-200 dark:border-neutral-800 rounded-lg overflow-hidden relative"
>
  <div
    class="tab-triggers flex overflow-x-auto border-b border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
  >
    {
      tabs.map((tab, i) => (
        <button
          class="tab-trigger px-4 py-2.5 text-sm transition-colors text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white shrink-0 aria-selected:relative aria-selected:text-indigo-600 dark:aria-selected:text-indigo-400 aria-selected:font-medium aria-selected:after:content-[''] aria-selected:after:absolute aria-selected:after:bottom-[-1px] aria-selected:after:left-0 aria-selected:after:right-0 aria-selected:after:h-[2px] aria-selected:after:bg-current"
          aria-selected={i === 0 ? "true" : "false"}
        >
          {tab}
        </button>
      ))
    }
  </div>
  <div class="tab-panels p-0 m-0 bg-white dark:bg-neutral-950">
    <slot />
  </div>
</div>

<script>
  let removeListeners: (() => void)[] = [];

  document.addEventListener("astro:before-swap", () => {
    removeListeners.forEach((fn) => fn());
    removeListeners = [];
  });

  document.addEventListener("astro:page-load", () => {
    const tabsContainers = document.querySelectorAll(".tabs-container");

    tabsContainers.forEach((container) => {
      const triggers = container.querySelectorAll("button[aria-selected]");
      const panels = container.lastElementChild?.children || [];

      Array.from(panels).forEach((p, i) => {
        if (i !== 0) p.setAttribute("hidden", "true");
      });

      triggers.forEach((trigger, index) => {
        const onClick = () => {
          triggers.forEach((t) => t.setAttribute("aria-selected", "false"));
          Array.from(panels).forEach((p) => p.setAttribute("hidden", "true"));

          trigger.setAttribute("aria-selected", "true");
          panels[index]?.removeAttribute("hidden");
        };

        trigger.addEventListener("click", onClick);
        removeListeners.push(() =>
          trigger.removeEventListener("click", onClick),
        );
      });
    });
  });
</script>
