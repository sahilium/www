---
import { siteConfig } from "@/config";
---

<div class="greeting" id="greeting-root">
    <span class="greeting-hello" id="greeting-hello"></span>
    <span class="greeting-language" id="greeting-language"></span>
</div>

<script define:vars={{ prodApiBaseUrl: siteConfig.apiBaseUrl }}>
    const apiBaseUrl = location.hostname === "localhost" || location.hostname === "127.0.0.1"
        ? "http://localhost:8080"
        : prodApiBaseUrl;

    function setGreeting() {
        fetch(`${apiBaseUrl}/api/greetings`, { signal: AbortSignal.timeout(5000) })
            .then(r => r.ok ? r.json() : [])
            .then(list => {
                if (!list.length) return;
                const i = Math.floor(Math.random() * list.length);
                const entry = list[i];

                const helloEl = document.getElementById('greeting-hello');
                const langEl = document.getElementById('greeting-language');
                if (!helloEl || !langEl) return;

                helloEl.textContent = entry.hello + ' 👋';

                langEl.innerHTML = '';
                const a = document.createElement('a');
                a.href = entry.about || '#';
                a.target = '_blank';
                a.rel = 'noreferrer';
                a.textContent = entry.language;
                a.className = 'greeting-link';
                langEl.appendChild(a);
            })
            .catch(() => {});
    }

    setGreeting();
    document.addEventListener('astro:page-load', setGreeting);
</script>

<style>
    .greeting {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.1rem;
    }

    .greeting-hello {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.2;
        font-family: var(--font-sans, "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif);
    }

    .greeting-language {
        font-size: 0.75rem;
    }

    .greeting-link {
        color: var(--accent);
        position: relative;
        text-decoration: none;
    }

    .greeting-link::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 100%;
        height: 2px;
        background-color: var(--accent);
        transform: scaleX(1);
    }

    @media (min-width: 640px) {
        .greeting-hello {
            font-size: 2rem;
        }
        .greeting-language {
            font-size: 0.8rem;
        }
    }
</style>
