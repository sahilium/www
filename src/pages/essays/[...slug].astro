---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Badge from "@/components/ui/Badge.astro";
import { Image } from "astro:assets";
import { siteConfig } from "@/config";
import { parseDate } from "@/utils/date";
import { calcReadTime } from "@/utils/reading-time";

export async function getStaticPaths() {
    const essays = await getCollection("essay");
    const published = essays.filter((e) => !e.data.draft);

    return published.map((essay) => ({
        params: { slug: essay.id },
        props: { essay },
    }));
}

const { essay } = Astro.props;
const { Content, headings } = await render(essay);

const readTime = calcReadTime(essay.body!);

const dateObj = parseDate(essay.data.date);
const formattedDate = dateObj.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const updatedDate = essay.data.updatedDate
    ? parseDate(essay.data.updatedDate)
    : null;
const ogImage = essay.data.image?.src;
const essayUrl = new URL(
    `/essays/${essay.id}`,
    siteConfig.url,
).href;
---

<Layout
    title={`${essay.data.title} | ${siteConfig.title}`}
    description={essay.data.frontmatter}
    image={ogImage}
>
    <main class="page">
        <article>
            <header class="flex flex-col items-start gap-4 mt-6 mb-8">
                <a
                    href="/essays"
                    class="text-xs text-muted-foreground hover:text-accent transition-colors"
                >
                    &larr; Essays
                </a>
                <h1 class="text-4xl font-sans">{essay.data.title}</h1>
                <div
                    class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted-foreground"
                >
                    <time datetime={essay.data.date}>
                        {formattedDate}
                    </time>
                    <span>{readTime} min read</span>
                    {updatedDate && (
                        <span>
                            Updated {updatedDate.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })}
                        </span>
                    )}
                </div>
                <div class="flex flex-wrap gap-2">
                    {essay.data.tags.map((tag: string) => (
                        <Badge content={tag} href={`/tags/${tag}`} />
                    ))}
                </div>
            </header>

            {essay.data.image && (
                <Image
                    src={essay.data.image}
                    alt={essay.data.title}
                    class="w-full rounded-lg mb-8"
                />
            )}

            <div class="prose-blog">
                <Content />
            </div>
        </article>
    </main>
</Layout>
