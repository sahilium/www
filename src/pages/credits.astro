---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="/credits | Sahil A.">
    <main class="page flex flex-col space-y-10">
        <section class="relative flex flex-col items-start gap-4">
            <span class="text-accent uppercase text-xs">// credits</span>
            <h1 class="text-5xl">Credits</h1>
        </section>

        <section class="prose-blog max-w-none">
            <p>This site is built with <a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a> using the <a href="https://github.com/jiseeeh/serene-ink" target="_blank" rel="noreferrer">serene-ink</a> theme.</p>
            <p>Several site design elements are inspired by <a href="https://boehs.org" target="_blank" rel="noreferrer">Evan Boehs</a> and his work at <a href="https://boehs.org" target="_blank" rel="noreferrer">boehs.org</a>.</p>
            <p>Content on this site is licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noreferrer">CC BY-NC-SA 4.0</a> unless otherwise noted.</p>
        </section>
    </main>
</Layout>
