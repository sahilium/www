---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { siteConfig } from "@/config";

const entries = await getCollection("post");
const posts = entries.filter((entry) => !entry.data.draft);

const tagCounts = new Map<string, number>();
posts.forEach((post) => {
    post.data.tags.forEach((tag) => {
        tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
    });
});

const sortedTags = [...tagCounts.entries()].sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0]);
});
---

<Layout title={`Tags | ${siteConfig.title}`}>
    <main class="page">
        <div class="mb-10">
            <a
                href="/"
                class="text-sm font-medium text-muted-foreground hover:text-primary transition-colors flex items-center gap-2"
            >
                <span>←</span> Back to writing
            </a>
        </div>

        <span class="uppercase text-primary font-medium tracking-widest"
            >browse</span
        >

        <h1 class="text-4xl mt-10">Tags</h1>
        <p class="text-lg max-w-122 text-muted-foreground">
            Explore posts by topic.
        </p>

        <section class="mt-20 flex flex-wrap gap-3">
            {
                sortedTags.map(([tag, count]) => (
                    <a
                        href={`/tags/${tag}`}
                        class="text-sm text-muted-foreground rounded-full bg-muted px-4 py-2 hover:bg-primary/10 hover:text-primary transition-colors"
                    >
                        {tag}{" "}
                        <span class="text-xs opacity-60">({count})</span>
                    </a>
                ))
            }
        </section>
    </main>
</Layout>
