---
import Writing from "@/components/Writing.astro";
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import Greeting from "@/components/Greeting.astro";
import { siteConfig } from "@/config";
import { Mail, Rss } from "@lucide/astro";
---

<Layout image="/images/home.webp">
    <Hero />

    <div class="px-10 lg:px-20 mt-4">
        <Greeting />
    </div>

    <div class="px-10 lg:px-20 mt-6 space-y-3">
        <p class="text-sm leading-relaxed text-foreground">
            I'm a developer and systems thinker who believes the best way to
            understand something is to take it apart and put it back together.
            This site is a digital garden where I document what I learn about
            software, Linux, and the occasional rabbit hole. I value
            simplicity, readability, and tools that stay out of your way.
            Everything here is built by hand, with intention.
        </p>
        <p class="text-sm leading-relaxed text-foreground">
            I'm drawn to terminal-first workflows, minimal desktops, and code
            that reads like prose. When I'm not tinkering with config files or
            rewriting the same script for the fifth time, I'm reading about
            programming languages, writing about the things I build, or staring
            at a prompt trying to figure out what to build next.
        </p>
    </div>

    <div class="px-10 lg:px-20 mt-5 flex justify-center">
        <button
            id="explore-cta"
            type="button"
            class="text-sm text-primary-foreground bg-accent rounded-md px-5 py-2.5 hover:opacity-90 transition-opacity cursor-pointer font-medium"
        >
            Explore the site &rarr;
            <kbd class="text-[10px] ml-2 opacity-70">^P</kbd>
        </button>
    </div>

    <script>
        const cta = document.getElementById('explore-cta');
        if (cta) {
            cta.addEventListener('click', () => {
                const toggle = document.getElementById('palette-toggle');
                if (toggle) toggle.click();
            });
        }
    </script>

    <section class="px-10 lg:px-20 mt-10">
        <span class="uppercase text-primary font-medium tracking-widest text-xs"
            >/status</span
        >
        <h1 class="text-xl mt-3 font-sans">Currently</h1>
        <p class="text-sm text-muted-foreground mt-1 max-w-prose leading-relaxed">
            What I'm up to right now — music, reading, building.
        </p>
        <a
            href="/now"
            class="text-sm text-accent hover:underline mt-2 inline-block"
        >
            see what I'm doing now &rarr;
        </a>
    </section>

    <section class="px-10 lg:px-20 mt-10">
        <span class="uppercase text-primary font-medium tracking-widest text-xs"
            >/blog</span
        >
        <h1 class="text-xl mt-3 font-sans">Latest writing</h1>
        <Writing page={1} preview={true} />
    </section>

    <section class="px-10 lg:px-20 mt-10 mb-16">
        <span class="uppercase text-primary font-medium tracking-widest text-xs"
            >/contact</span
        >
        <h1 class="text-xl mt-3 font-sans">Get in touch</h1>
        <p class="text-sm text-muted-foreground mt-1 max-w-prose leading-relaxed">
            Reach out anytime.
        </p>
        <div class="flex items-center gap-4 mt-4">
            {
                siteConfig.socials.email && (
                    <a
                        href={siteConfig.socials.email}
                        aria-label="Email"
                        class="text-muted-foreground hover:text-primary transition-colors"
                    >
                        <Mail size={18} />
                    </a>
                )
            }
            {
                siteConfig.socials.github && (
                    <a
                        href={siteConfig.socials.github}
                        target="_blank"
                        rel="noreferrer"
                        aria-label="GitHub"
                        class="text-muted-foreground hover:text-primary transition-colors"
                    >
                        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                    </a>
                )
            }
            {
                siteConfig.socials.linkedin && (
                    <a
                        href={siteConfig.socials.linkedin}
                        target="_blank"
                        rel="noreferrer"
                        aria-label="LinkedIn"
                        class="text-muted-foreground hover:text-primary transition-colors"
                    >
                        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </a>
                )
            }
            <a
                href="/feed.xml"
                aria-label="RSS"
                class="text-muted-foreground hover:text-primary transition-colors"
            >
                <Rss size={18} />
            </a>
        </div>
    </section>
</Layout>