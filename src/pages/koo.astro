---
import Layout from "@/layouts/Layout.astro";
import { allKo, getCurrentKo, getPreviousKo, getNextKo } from "@/data/ko";

const current = getCurrentKo();
const previous = getPreviousKo(current);
const next = getNextKo(current);
const totalKo = allKo.length;
---

<Layout title="/koo | Sahil A.">
    <main class="page flex flex-col space-y-10">
        <section class="flex flex-col items-start gap-4">
            <span class="text-accent uppercase text-xs">// kō</span>
            <h1 class="text-5xl">七十二候</h1>
            <p class="text-sm text-muted-foreground leading-relaxed">
                The <em>Shichijūnikō</em> (七十二候) are the 72 microseasons
                of the traditional Japanese calendar. Each kō (候) lasts
                approximately five days, marking the subtle shifts in nature
                — from the first thaw to the last frost.
            </p>
        </section>

        <section class="border border-border rounded-xl p-8 bg-card">
            <span class="text-[10px] uppercase tracking-widest text-muted-foreground font-medium"
                >Current microseason</span
            >

            <div class="mt-6 space-y-1 text-base leading-relaxed">
                <p>
                    The current <em>候</em> (kō), microseason,
                    <br />
                    in the traditional Japanese calendar is
                </p>
                <p class="text-2xl font-sans font-medium mt-2">
                    {current.kanji}
                </p>
                <p class="text-muted-foreground">
                    {current.romaji}
                </p>
                <p class="text-muted-foreground">{current.en}.</p>
                <p class="mt-2">
                    in the division of
                    <br />
                    <span class="font-medium">{current.sekki}</span>
                    <span class="text-muted-foreground">
                        ({current.sekkiRomaji})</span
                    >,
                    <br />
                    <span class="text-muted-foreground">{current.sekkiEn}.</span>
                </p>
            </div>
        </section>

        <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="border border-border rounded-xl p-6 bg-card">
                <span class="text-[10px] uppercase tracking-widest text-muted-foreground font-medium"
                    >Previous</span
                >
                <div class="mt-3 space-y-1">
                    <p class="text-lg font-sans font-medium">{previous.kanji}</p>
                    <p class="text-xs text-muted-foreground">
                        {previous.romaji}
                    </p>
                    <p class="text-sm text-muted-foreground">{previous.en}.</p>
                    <p class="text-xs text-muted-foreground mt-1">
                        {previous.sekki} ({previous.sekkiRomaji}) &middot;
                        {previous.sekkiEn}
                    </p>
                </div>
            </div>

            <div class="border border-border rounded-xl p-6 bg-card">
                <span class="text-[10px] uppercase tracking-widest text-muted-foreground font-medium"
                    >Next</span
                >
                <div class="mt-3 space-y-1">
                    <p class="text-lg font-sans font-medium">{next.kanji}</p>
                    <p class="text-xs text-muted-foreground">
                        {next.romaji}
                    </p>
                    <p class="text-sm text-muted-foreground">{next.en}.</p>
                    <p class="text-xs text-muted-foreground mt-1">
                        {next.sekki} ({next.sekkiRomaji}) &middot;
                        {next.sekkiEn}
                    </p>
                </div>
            </div>
        </section>

        <section>
            <h2 class="text-sm font-sans font-medium mb-4">
                All {totalKo} microseasons
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
                {allKo.map((ko) => {
                    const isActive = ko.id === current.id;
                    return (
                        <div
                            class:list={[
                                "border rounded-lg p-3 text-sm transition-colors",
                                isActive
                                    ? "border-accent bg-accent/10"
                                    : "border-border bg-card",
                            ]}
                        >
                            <div class="flex items-center justify-between">
                                <span class="text-muted-foreground text-[10px] font-mono">
                                    #{ko.id}
                                </span>
                                {isActive && (
                                    <span class="text-[10px] text-accent uppercase font-medium"
                                        >active</span
                                    >
                                )}
                            </div>
                            <p class="font-sans font-medium mt-1 text-sm">
                                {ko.kanji}
                            </p>
                            <p class="text-xs text-muted-foreground mt-0.5">
                                {ko.romaji}
                            </p>
                        </div>
                    );
                })}
            </div>
        </section>
    </main>
</Layout>
