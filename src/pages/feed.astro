---
import Layout from "@/layouts/Layout.astro";
import { siteConfig } from "@/config";
---

<Layout title="/feed | Sahil A.">
    <main class="page flex flex-col space-y-10">
        <section class="relative flex flex-col items-start gap-4">
            <span class="text-accent uppercase text-xs">// feed</span>
            <h1 class="text-5xl">Feed</h1>
            <p class="text-sm text-muted-foreground">
                Updated: <span id="feed-updated">...</span>
            </p>
        </section>

        <section class="prose-blog" id="feed-content">
            <p class="text-muted-foreground">Loading...</p>
        </section>

        <!-- End marker -->
        <div class="flex items-center justify-center gap-4 text-muted-foreground text-sm pt-4 pb-10">
            <div class="h-px w-full bg-foreground/10"></div>
            <span class="whitespace-nowrap uppercase tracking-widest">fin</span>
            <div class="h-px w-full bg-foreground/10"></div>
        </div>
    </main>
</Layout>

<script define:vars={{ prodApiBaseUrl: siteConfig.apiBaseUrl }}>
    const feedContent = document.getElementById("feed-content");
    const feedUpdated = document.getElementById("feed-updated");

    const apiBaseUrl =
        location.hostname === "localhost" || location.hostname === "127.0.0.1"
            ? "http://localhost:8080"
            : prodApiBaseUrl;

    feedUpdated && (feedUpdated.textContent = new Date().toLocaleDateString("en-US", {
        year: "numeric", month: "long", day: "numeric",
    }));

    function renderMarkdown(md) {
        const lines = md.split("\n");
        let html = "";
        let inList = false;
        for (let line of lines) {
            if (line.startsWith("# ")) {
                if (inList) { html += "</ul>"; inList = false; }
                html += `<h1>${line.slice(2)}</h1>`;
            } else if (line.startsWith("## ")) {
                if (inList) { html += "</ul>"; inList = false; }
                html += `<h2>${line.slice(3)}</h2>`;
            } else if (line.startsWith("### ")) {
                if (inList) { html += "</ul>"; inList = false; }
                html += `<h3>${line.slice(4)}</h3>`;
            } else if (line.startsWith("- ")) {
                if (!inList) { html += "<ul>"; inList = true; }
                html += `<li>${line.slice(2)}</li>`;
            } else if (line.startsWith("> ")) {
                if (inList) { html += "</ul>"; inList = false; }
                html += `<blockquote>${line.slice(2)}</blockquote>`;
            } else if (line.trim() === "") {
                if (inList) { html += "</ul>"; inList = false; }
                html += "<br/>";
            } else {
                if (inList) { html += "</ul>"; inList = false; }
                html += `<p>${line}</p>`;
            }
        }
        if (inList) html += "</ul>";
        return html;
    }

    fetch(`${apiBaseUrl}/api/cms/feed`, { signal: AbortSignal.timeout(8000) })
        .then((r) => {
            if (!r.ok) throw new Error(`status ${r.status}`);
            return r.json();
        })
        .then((data) => {
            if (!data || !data.content) {
                feedContent.innerHTML = `<p class="text-muted-foreground">Nothing yet — write in Obsidian and it&rsquo;ll appear here.</p>`;
                return;
            }
            feedContent.innerHTML = renderMarkdown(data.content);
            if (data.updated && feedUpdated) {
                const d = new Date(data.updated);
                feedUpdated.textContent = d.toLocaleDateString("en-US", {
                    year: "numeric", month: "long", day: "numeric",
                    hour: "2-digit", minute: "2-digit",
                });
            }
        })
        .catch(() => {
            feedContent.innerHTML = `<p class="text-muted-foreground">Could not load feed.</p>`;
        });
</script>
